# ============================================
# EventManager - Configuración de Entorno
# ============================================
# Este archivo contiene los valores por DEFECTO para DESARROLLO LOCAL.
# Coolify sobrescribirá estas variables automáticamente en producción.
# NO necesitas cambiar nada para que funcione en producción.

# ---- Servidor ----
PORT=3000
NODE_ENV=development
APP_NAME=EventManager
JWT_SECRET=dev_secret_change_in_production

# ---- Base de Datos ----
DB_HOST=localhost        # En Coolify: usa el nombre del servicio PostgreSQL
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=event_manager

# ---- Archivos ----
UPLOAD_DIR=uploads

# ---- CORS ----
# Desarrollo: http://localhost:3001
# Producción: https://tu-dominio.com (URL del frontend)
CORS_ORIGIN=http://localhost:3001

# ---- Admin (solo para desarrollo/inicialización) ----
ADMIN_FULL_NAME=Admin Local
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=admin123
